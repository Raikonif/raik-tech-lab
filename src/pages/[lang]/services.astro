---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";
import { Icon } from "astro-icon/components";
import { getFeatures } from "@data/home";
import { locales, type Locale, withLocalePath } from "@i18n/config";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const features = getFeatures(lang);

const serviceAnchors = ["digitalizacion", "ecommerce", "mvp", "ia", "fintech"];
---

<Layout
  lang={lang}
  title={lang === "es" ? "Servicios" : "Services"}
  description={
    lang === "es"
      ? "Conoce nuestros servicios de landing pages, sistemas personalizados, ERP/CRM y automatizacion con IA para escalar operaciones."
      : "Explore our services: landing pages, custom systems, ERP/CRM, and AI automation to scale operations."
  }
  openGraphTitle={lang === "es" ? "Servicios de Software | RaiKode Solutions" : "Software Services | RaiKode Solutions"}
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">
        {lang === "es"
          ? "Servicios para empresas y startups en Latinoamerica"
          : "Services for companies and startups in Latin America"}
      </Fragment>
      <Fragment slot="desc">
        {lang === "es"
          ? "Diseñamos software con foco en retorno de inversion: menos trabajo manual, mas ventas y mejor control operativo."
          : "We build software focused on ROI: less manual work, more sales, and better operational control."}
      </Fragment>
    </Sectionhead>

    <section class="mt-14 grid gap-6">
      {
        features.map((service, index) => (
          <article
            id={serviceAnchors[index]}
            class="rounded-xl border border-slate-200 bg-white p-6 md:p-8 shadow-sm">
            <div class="flex items-start gap-4">
              <div class={`${service.color} mt-1 flex h-12 w-12 shrink-0 items-center justify-center rounded-full`}>
                <Icon class="h-6 w-6 text-white" name={service.icon} />
              </div>
              <div>
                <h2 class="text-2xl font-bold text-slate-900">{service.title}</h2>
                <p class="mt-2 text-lg text-slate-600">{service.description}</p>
              </div>
            </div>
          </article>
        ))
      }
    </section>

    <section class="mt-14 rounded-2xl bg-slate-900 p-8 md:p-10 text-white">
      <h2 class="text-3xl md:text-4xl font-bold">
        {lang === "es" ? "Resultados que priorizamos" : "Outcomes we prioritize"}
      </h2>
      <div class="mt-6 grid md:grid-cols-3 gap-4">
        <div class="rounded-lg border border-slate-700 bg-slate-800/60 p-4">
          <h3 class="text-xl font-semibold">{lang === "es" ? "Velocidad comercial" : "Commercial speed"}</h3>
          <p class="mt-2 text-slate-300">
            {lang === "es"
              ? "Reducimos el tiempo entre primer contacto y venta."
              : "We reduce the time from first contact to close."}
          </p>
        </div>
        <div class="rounded-lg border border-slate-700 bg-slate-800/60 p-4">
          <h3 class="text-xl font-semibold">{lang === "es" ? "Control operativo" : "Operational control"}</h3>
          <p class="mt-2 text-slate-300">
            {lang === "es"
              ? "Centralizamos datos para decidir con informacion real."
              : "We centralize data for better decision-making."}
          </p>
        </div>
        <div class="rounded-lg border border-slate-700 bg-slate-800/60 p-4">
          <h3 class="text-xl font-semibold">{lang === "es" ? "Escalabilidad" : "Scalability"}</h3>
          <p class="mt-2 text-slate-300">
            {lang === "es"
              ? "Construimos una base tecnica lista para crecimiento sostenido."
              : "We build a technical foundation ready for sustained growth."}
          </p>
        </div>
      </div>

      <div class="mt-8 flex flex-col sm:flex-row gap-3">
        <Link href={withLocalePath(lang, "/contact")} style="inverted">
          {lang === "es" ? "Solicitar propuesta" : "Request proposal"}
        </Link>
        <Link href={withLocalePath(lang, "/market")} style="outline" class="!border-white !text-white hover:!bg-slate-700">
          {lang === "es" ? "Ver contexto de mercado" : "View market context"}
        </Link>
      </div>
    </section>
  </Container>
</Layout>
