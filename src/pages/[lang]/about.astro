---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { isPublished } from "@utils/content";
import { locales, type Locale } from "@i18n/config";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };

const publishedTeamMembers = await getCollection("team", ({ data }) => {
  return isPublished(data.publishDate, data.draft);
});
---

<Layout
  lang={lang}
  title={lang === "es" ? "Sobre Nosotros" : "About"}
  description={
    lang === "es"
      ? "Somos un equipo de desarrollo y producto enfocado en crecimiento digital para empresas y startups de Latinoamerica."
      : "We are a product and engineering team focused on digital growth for companies and startups across Latin America."
  }
  openGraphTitle={lang === "es" ? "Sobre Nosotros | RaiKode Solutions" : "About Us | RaiKode Solutions"}
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">{lang === "es" ? "Sobre Nosotros" : "About Us"}</Fragment>
      <Fragment slot="desc">
        {lang === "es"
          ? "Equipo enfocado en crecimiento digital real para Latinoamerica."
          : "Team focused on real digital growth across Latin America."}
      </Fragment>
    </Sectionhead>

    <div class="flex flex-col gap-3 mx-auto max-w-4xl mt-16">
      <h2 class="font-bold text-3xl text-gray-800">
        {lang === "es"
          ? "Construimos tecnologia que mejora ventas, operaciones y decisiones."
          : "We build technology that improves revenue, operations, and decisions."}
      </h2>
      <p class="text-lg leading-relaxed text-slate-500">
        {lang === "es"
          ? "Trabajamos con empresas tradicionales, pymes y startups que quieren digitalizarse sin perder meses en proyectos eternos. Combinamos estrategia de negocio, producto y desarrollo para entregar soluciones utiles desde la primera version."
          : "We work with traditional companies, SMBs, and startups that need practical digitization without endless project cycles. We combine business strategy, product thinking, and engineering to deliver useful solutions from the first release."}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-10 mx-auto max-w-4xl mt-12">
      {
        publishedTeamMembers.map((teamMemberEntry) => (
          <div class="group">
            <div class="w-full aspect-square">
              <Picture
                src={teamMemberEntry.data.avatar.src}
                alt={teamMemberEntry.data.avatar.alt}
                sizes="(max-width: 800px) 100vw, 400px"
                width={400}
                height={400}
                class="w-full rounded-md rounded transition group-hover:-translate-y-1 group-hover:shadow-xl bg-white object-cover object-center aspect-square"
              />
            </div>

            <div class="mt-4 text-center">
              <h2 class="text-lg text-gray-800">{teamMemberEntry.data.name}</h2>
              <h3 class="text-sm text-slate-500">{teamMemberEntry.data.title}</h3>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</Layout>
