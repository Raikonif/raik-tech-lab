---
import { getCollection } from "astro:content";
import { Picture } from "astro:assets";
import Layout from "@layouts/Layout.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import { getFormattedDate } from "@utils/all";
import { isPublished, sortByPublishDateDesc } from "@utils/content";
import { locales, type Locale, withLocalePath } from "@i18n/config";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };

const publishedBlogEntries = await getCollection("blog", ({ data }) => {
  return isPublished(data.publishDate, data.draft);
});

sortByPublishDateDesc(publishedBlogEntries);
---

<Layout
  lang={lang}
  title="Blog"
  description={
    lang === "es"
      ? "Guias y estrategias de desarrollo, automatizacion e innovacion digital para crecer con tecnologia en Latinoamerica."
      : "Guides and strategies on development, automation, and digital innovation for growth in Latin America."
  }
  openGraphTitle={lang === "es" ? "Blog de Tecnologia y Negocio | RaiKode Solutions" : "Technology & Business Blog | RaiKode Solutions"}
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">{lang === "es" ? "Nuestro Blog" : "Our Blog"}</Fragment>
      <Fragment slot="desc">
        {lang === "es"
          ? "Estrategias y tendencias para crecer con tecnologia en Latinoamerica."
          : "Strategies and trends to scale with technology in Latin America."}
      </Fragment>
    </Sectionhead>

    <main class="mt-16">
      <ul class="grid gap-16 max-w-4xl mx-auto">
        {
          publishedBlogEntries.map((blogPostEntry, index) => (
            <li>
              <a href={`${withLocalePath(lang, "/blog")}/${blogPostEntry.id}`}>
                <div class="grid md:grid-cols-2 gap-5 md:gap-10 items-center">
                  <Picture
                    src={blogPostEntry.data.image.src}
                    alt={blogPostEntry.data.image.alt}
                    sizes="(max-width: 800px) 100vw, 800px"
                    width={800}
                    height={600}
                    loading={index <= 2 ? "eager" : "lazy"}
                    decoding={index <= 2 ? "sync" : "async"}
                    class="w-full rounded-md object-cover object-center bg-white"
                  />
                  <div>
                    <span class="text-blue-400 uppercase tracking-wider text-sm font-medium">
                      {blogPostEntry.data.category}
                    </span>

                    <h2 class="text-3xl font-semibold leading-snug tracking-tight mt-1 ">
                      {blogPostEntry.data.title}
                    </h2>

                    <div class="flex gap-2 mt-3">
                      <span class="text-gray-400">{blogPostEntry.data.author}</span>
                      <span class="text-gray-400">• </span>
                      <time class="text-gray-400" datetime={blogPostEntry.data.publishDate.toISOString()}>
                        {getFormattedDate(blogPostEntry.data.publishDate)}
                      </time>
                    </div>
                  </div>
                </div>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
  </Container>
</Layout>
