---
import Contactform from "@components/contactform.astro";
import Container from "@components/container.astro";
import Sectionhead from "@components/sectionhead.astro";
import Layout from "@layouts/Layout.astro";
import { getContactInfo } from "@data/contact";
import { locales, type Locale } from "@i18n/config";
import { Icon } from "astro-icon/components";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const contactInfo = getContactInfo(lang);
---

<Layout
  lang={lang}
  title={lang === "es" ? "Contacto" : "Contact"}
  description={
    lang === "es"
      ? "Agenda una reunion para evaluar tu proyecto digital y recibir una propuesta de desarrollo, automatizacion o integracion."
      : "Book a call to review your digital project and get a proposal for development, automation, or integrations."
  }
  openGraphTitle={lang === "es" ? "Contacto | RaiKode Solutions" : "Contact | RaiKode Solutions"}
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">
        {lang === "es" ? "Conversemos sobre tu crecimiento digital" : "Let's talk about your digital growth"}
      </Fragment>
      <Fragment slot="desc">
        {lang === "es" ? "Respondemos en menos de 24 horas habiles." : "We typically reply within 24 business hours."}
      </Fragment>
    </Sectionhead>

    <div class="grid md:grid-cols-2 gap-10 mx-auto max-w-4xl mt-16">
      <div>
        <h2 class="font-medium text-2xl text-gray-800">{contactInfo.heading}</h2>
        <p class="text-lg leading-relaxed text-slate-500 mt-3">
          {contactInfo.description}
        </p>
        <div class="mt-5">
          <div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:map-marker" />
            <span>{contactInfo.location}</span>
          </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:envelope" /><a
              href={`mailto:${contactInfo.email}`}
              >{contactInfo.email}</a
            >
          </div><div class="flex items-center mt-2 space-x-2 text-gray-600">
            <Icon class="text-gray-400 w-4 h-4" name="uil:phone" /><a
              href={`tel:${contactInfo.phone}`}>{contactInfo.phone}</a
            >
          </div>
        </div>
      </div>
      <div>
        <Contactform lang={lang} />
      </div>
    </div>
  </Container>
</Layout>
