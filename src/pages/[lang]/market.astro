---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";
import { getMarketHighlights } from "@data/home";
import { locales, type Locale, withLocalePath } from "@i18n/config";

export function getStaticPaths() {
  return locales.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Locale };
const marketHighlights = getMarketHighlights(lang);
---

<Layout
  lang={lang}
  title={lang === "es" ? "Mercado Latam" : "Latam Market"}
  description={
    lang === "es"
      ? "Analisis del mercado digital en Latinoamerica: oportunidades de software, IA, pagos y transformacion operativa para empresas."
      : "Digital market analysis for Latin America: opportunities in software, AI, payments, and operational transformation."
  }
  openGraphTitle={
    lang === "es"
      ? "Mercado Digital en Latinoamerica | RaiKode Solutions"
      : "Digital Market in Latin America | RaiKode Solutions"
  }
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">
        {lang === "es"
          ? "Latinoamerica: mercado en crecimiento, aun temprano"
          : "Latin America: growing market, still early stage"}
      </Fragment>
      <Fragment slot="desc">
        {lang === "es"
          ? "Existe demanda real de software, pero muchos mercados siguen siendo sensibles a precio. La estrategia ganadora es entregar alto impacto operativo en fases claras."
          : "There is real software demand, but many markets remain price-sensitive. Winning strategy means delivering high operational impact in clear phases."}
      </Fragment>
    </Sectionhead>

    <section class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        marketHighlights.map((item) => (
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <p class="text-3xl font-bold text-slate-900">{item.value}</p>
            <p class="mt-2 text-slate-600">{item.label}</p>
          </article>
        ))
      }
    </section>

    <section class="mt-14 grid lg:grid-cols-2 gap-8">
      <article class="rounded-xl border border-slate-200 p-6 bg-white">
        <h2 class="text-2xl font-bold">{lang === "es" ? "Que compran hoy los clientes" : "What clients are buying today"}</h2>
        <ul class="mt-4 space-y-3 text-slate-600 list-disc pl-5">
          <li>{lang === "es" ? "Sistemas internos que reemplacen tareas manuales." : "Internal systems replacing manual tasks."}</li>
          <li>{lang === "es" ? "E-commerce con pagos y control de pedidos." : "E-commerce with payment and order control."}</li>
          <li>{lang === "es" ? "MVPs para validar nuevas ideas rapidamente." : "MVPs to validate ideas quickly."}</li>
          <li>{lang === "es" ? "Automatizacion con IA donde el equipo pierde mas tiempo." : "AI automation where teams lose most time."}</li>
          <li>{lang === "es" ? "Soluciones fintech y paneles financieros simples de usar." : "Fintech solutions and simple financial dashboards."}</li>
        </ul>
      </article>

      <article class="rounded-xl border border-slate-200 p-6 bg-white">
        <h2 class="text-2xl font-bold">{lang === "es" ? "Como competir en un mercado sensible a precio" : "How to compete in a price-sensitive market"}</h2>
        <ul class="mt-4 space-y-3 text-slate-600 list-disc pl-5">
          <li>{lang === "es" ? "Partir por casos de uso con retorno rapido." : "Start with fast ROI use cases."}</li>
          <li>{lang === "es" ? "Vender por resultados, no por horas ni tecnologia." : "Sell by outcomes, not hours or tooling."}</li>
          <li>{lang === "es" ? "Implementar en etapas para reducir riesgo del cliente." : "Roll out in phases to reduce risk."}</li>
          <li>{lang === "es" ? "Medir productividad, ventas y ahorro desde el primer mes." : "Measure productivity, sales, and savings from month one."}</li>
          <li>{lang === "es" ? "Escalar solo despues de validar traccion." : "Scale only after traction is validated."}</li>
        </ul>
      </article>
    </section>

    <section class="mt-14 rounded-2xl bg-emerald-50 border border-emerald-200 p-8">
      <h2 class="text-3xl font-bold text-emerald-900">{lang === "es" ? "Tu ventaja: combinar desarrollo y negocio" : "Your edge: combine engineering and business"}</h2>
      <p class="mt-3 text-lg text-emerald-800 max-w-3xl">
        {lang === "es"
          ? "Las empresas de la region necesitan socios tecnicos que entiendan operacion, ventas y experiencia del cliente. Si conviertes tecnologia en resultados, la demanda ya esta esperandote."
          : "Regional companies need technical partners who understand operations, sales, and customer experience. If you turn technology into outcomes, demand is already there."}
      </p>
      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <Link href={withLocalePath(lang, "/services")}>{lang === "es" ? "Explorar servicios" : "Explore services"}</Link>
        <Link href={withLocalePath(lang, "/contact")} style="outline">{lang === "es" ? "Agendar reunion" : "Book a call"}</Link>
      </div>
    </section>
  </Container>
</Layout>
