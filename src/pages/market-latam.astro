---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
import Sectionhead from "@components/sectionhead.astro";
import Link from "@components/ui/link.astro";
import { getMarketHighlights } from "@data/home";

const marketHighlights = getMarketHighlights("es");
---

<Layout
  title="Mercado Latam"
  description="Analisis del mercado digital en Latinoamerica: oportunidades de software, IA, pagos y transformacion operativa para empresas."
  openGraphTitle="Mercado Digital en Latinoamerica | Raicode Latam"
>
  <Container>
    <Sectionhead>
      <Fragment slot="title">Latinoamerica: mercado en crecimiento, aun temprano</Fragment>
      <Fragment slot="desc">
        Existe demanda real de software, pero muchos mercados siguen siendo sensibles a
        precio. La estrategia ganadora es entregar alto impacto operativo en
        fases claras.
      </Fragment>
    </Sectionhead>

    <section class="mt-12 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {
        marketHighlights.map((item) => (
          <article class="rounded-xl border border-slate-200 bg-white p-5">
            <p class="text-3xl font-bold text-slate-900">{item.value}</p>
            <p class="mt-2 text-slate-600">{item.label}</p>
          </article>
        ))
      }
    </section>

    <section class="mt-14 grid lg:grid-cols-2 gap-8">
      <article class="rounded-xl border border-slate-200 p-6 bg-white">
        <h2 class="text-2xl font-bold">Que compran hoy los clientes</h2>
        <ul class="mt-4 space-y-3 text-slate-600 list-disc pl-5">
          <li>Sistemas internos que reemplacen tareas manuales.</li>
          <li>E-commerce con pagos y control de pedidos.</li>
          <li>MVPs para validar nuevas ideas rapidamente.</li>
          <li>Automatizacion con IA donde el equipo pierde mas tiempo.</li>
          <li>Soluciones fintech y paneles financieros simples de usar.</li>
        </ul>
      </article>

      <article class="rounded-xl border border-slate-200 p-6 bg-white">
        <h2 class="text-2xl font-bold">Como competir en un mercado sensible a precio</h2>
        <ul class="mt-4 space-y-3 text-slate-600 list-disc pl-5">
          <li>Partir por casos de uso con retorno rapido.</li>
          <li>Vender por resultados, no por horas ni tecnologia.</li>
          <li>Implementar en etapas para reducir riesgo del cliente.</li>
          <li>Medir productividad, ventas y ahorro desde el primer mes.</li>
          <li>Escalar solo despues de validar traccion.</li>
        </ul>
      </article>
    </section>

    <section class="mt-14 rounded-2xl bg-emerald-50 border border-emerald-200 p-8">
      <h2 class="text-3xl font-bold text-emerald-900">Tu ventaja: combinar desarrollo y negocio</h2>
      <p class="mt-3 text-lg text-emerald-800 max-w-3xl">
        Las empresas de la region necesitan socios tecnicos que entiendan operacion,
        ventas y experiencia del cliente. Si conviertes tecnologia en resultados,
        la demanda ya esta esperandote.
      </p>
      <div class="mt-6 flex flex-col sm:flex-row gap-3">
        <Link href="/services">Explorar servicios</Link>
        <Link href="/contact" style="outline">Agendar reunion</Link>
      </div>
    </section>
  </Container>
</Layout>
