---
import Container from "@components/container.astro";
import Layout from "@layouts/Layout.astro";
---

<Layout
  title="404 Not Found"
  description="La pagina que buscas no existe o fue movida."
  noindex={true}
>
  <Container>
    <div class="min-h-[calc(100vh-16rem)] flex items-center justify-center">
      <div class="mt-16 text-center">
        <h1 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">404</h1>
        <p class="text-lg mt-4 text-slate-600">Pagina no encontrada.</p>
        <a
          href="/"
          class="inline-block mt-6 rounded bg-black px-5 py-2.5 text-white hover:bg-slate-800 transition">
          Volver al inicio
        </a>
      </div>
    </div>
  </Container>
</Layout>
