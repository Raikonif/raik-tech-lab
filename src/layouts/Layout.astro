---
import { SEO } from "astro-seo";
import Footer from "@components/footer.astro";
import Navbar from "@components/navbar/navbar.astro";
import { getSiteConfig } from "@data/site";
import type { Locale } from "@i18n/config";
import favicon from "@assets/simple-fox-logo.png";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque/index.css";
import "../styles.css"



export interface Props {
  title: string;
  lang?: Locale;
  description?: string;
  openGraphTitle?: string;
  openGraphType?: "website" | "article";
  openGraphImage?: string;
  openGraphImageAlt?: string;
  noindex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();

const resolvedImageWithDomain = new URL(
  "/opengraph.jpg",
  Astro.site
).toString();

const {
  title,
  lang = "es",
  description,
  openGraphTitle,
  openGraphType = "website",
  openGraphImage,
  openGraphImageAlt,
  noindex = false,
} = Astro.props;

const siteConfig = getSiteConfig(lang);

const makeTitle = title
  ? title + " | " + siteConfig.metadata.titleSuffix
  : siteConfig.metadata.titleSuffix;

const resolvedDescription = description || siteConfig.metadata.description;
const resolvedOgTitle = openGraphTitle || makeTitle;
const resolvedOgImage = openGraphImage || resolvedImageWithDomain;
const resolvedOgImageAlt = openGraphImageAlt || siteConfig.metadata.openGraphImageAlt;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <meta name="generator" content={Astro.generator} />

    <!-- <link rel="preload" as="image" href={src} alt="Hero" /> -->
    <SEO
      title={makeTitle}
      description={resolvedDescription}
      canonical={canonicalURL}
      noindex={noindex}
      nofollow={noindex}
      twitter={{
        creator: siteConfig.social.twitterHandle,
        site: siteConfig.social.twitterHandle,
        card: "summary_large_image",
      }}
      openGraph={{
        basic: {
          url: canonicalURL,
          type: openGraphType,
          title: resolvedOgTitle,
          image: resolvedOgImage,
        },
        image: {
          alt: resolvedOgImageAlt,
        },
      }}
    />
  </head>
  <body>
    <Navbar lang={lang} />
    <slot />
    <Footer lang={lang} />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
  </body>
</html>
