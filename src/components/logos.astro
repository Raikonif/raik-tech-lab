---
// @ts-ignore
import { Icon } from "astro-icon/components";
import { getLogoSectionTitle, technologyIcons } from "@data/home";
import type { Locale } from "@i18n/config";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const logoSectionTitle = getLogoSectionTitle(lang);
---

<div class="mt-24">
  <h2 class="text-center text-slate-500">{logoSectionTitle}</h2>
  <div class="flex gap-8 md:gap-20 items-center justify-center mt-10 flex-wrap animate-scroll">
    {
      technologyIcons.map((item) => (
        <Icon class={item.className} name={item.name} />
      ))
    }
  </div>
</div>
