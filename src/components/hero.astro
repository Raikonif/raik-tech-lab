---
import { Picture } from "astro:assets";
import heroImage from "assets/hero-alt2.png";
import Link from "@components/ui/link.astro";
import { getHeroContent, getMarketHighlights } from "@data/home";
import type { Locale } from "@i18n/config";
import { Icon } from "astro-icon/components";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const heroContent = getHeroContent(lang);
const marketHighlights = getMarketHighlights(lang);
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-20 pb-8 md:pt-24 md:pb-24">
  <div class="py-6 md:order-1 hidden md:block">
    <Picture
      src={heroImage}
      alt="Astronaut in the air"
      widths={[200, 400, 600]}
      sizes="(max-width: 800px) 100vw, 620px"
      loading="eager"
      format="avif"
    />
  </div>
  <div>
    <span class="inline-flex items-center rounded-full bg-slate-100 px-4 py-1.5 text-sm font-medium text-slate-700">
      {heroContent.badge}
    </span>
    <h1
      class="mt-4 text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      {heroContent.title}
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      {heroContent.description}
    </p>
    <div class="mt-6 grid grid-cols-2 gap-3 max-w-2xl">
      {
        marketHighlights.map((item) => (
          <div class="rounded-lg border border-slate-200 bg-white px-4 py-3">
            <p class="text-2xl font-bold text-slate-900">{item.value}</p>
            <p class="text-sm text-slate-600 mt-1">{item.label}</p>
          </div>
        ))
      }
    </div>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href={heroContent.primaryCta.href}
        class="flex gap-1 items-center justify-center"
        rel="noopener">
        <Icon class="text-white w-5 h-5" name={heroContent.primaryCta.icon} />

         {heroContent.primaryCta.label}
      </Link>
      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href={heroContent.secondaryCta.href}
        class="flex gap-1 items-center justify-center">
        <Icon class="text-black w-4 h-4" name={heroContent.secondaryCta.icon} />
         {heroContent.secondaryCta.label}
      </Link>
    </div>
  </div>
</main>
