---
import { Picture } from "astro:assets";
import heroImage from "assets/hero-alt2.png";
import Link from "@components/ui/link.astro";
import { heroContent } from "@data/home";
import { Icon } from "astro-icon/components";
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-20 pb-8 md:pt-24 md:pb-24">
  <div class="py-6 md:order-1 hidden md:block">
    <Picture
      src={heroImage}
      alt="Astronaut in the air"
      widths={[200, 400, 600]}
      sizes="(max-width: 800px) 100vw, 620px"
      loading="eager"
      format="avif"
    />
  </div>
  <div>
    <h1
      class="text-5xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter">
      {heroContent.title}
    </h1>
    <p class="text-lg mt-4 text-slate-600 max-w-xl">
      {heroContent.description}
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href={heroContent.primaryCta.href}
        target="_blank"
        class="flex gap-1 items-center justify-center"
        rel="noopener">
        <Icon class="text-white w-5 h-5" name={heroContent.primaryCta.icon} />

         {heroContent.primaryCta.label}
      </Link>
      <Link
        size="lg"
        style="outline"
        rel="noopener"
        href={heroContent.secondaryCta.href}
        class="flex gap-1 items-center justify-center"
        target="_blank">
        <Icon class="text-black w-4 h-4" name={heroContent.secondaryCta.icon} />
         {heroContent.secondaryCta.label}
      </Link>
    </div>
  </div>
</main>
