---
import { Icon } from "astro-icon/components";
import { getFeatures, getFeaturesSection } from "@data/home";
import type { Locale } from "@i18n/config";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const features = getFeatures(lang);
const featuresSection = getFeaturesSection(lang);
---

<div class="mt-16 md:mt-0">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    {featuresSection.title}
  </h2>
  <p class="text-lg mt-4 text-slate-600">
    {featuresSection.description}
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-3 mt-16 gap-16">
  {
    features.map((item, index) => (
      <article
        id={[
          "digitalizacion",
          "ecommerce",
          "mvp",
          "ia",
          "fintech",
        ][index]}
        class="flex gap-4 items-start rounded-xl border border-slate-200 p-5 transition hover:-translate-y-1 hover:shadow-lg bg-white">
        <div class={`${item.color} flex mt-1 rounded-full items-center justify-center p-2 w-12 h-12 shrink-0`}>
          <Icon class="text-white h-6 w-6" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg">{item.title}</h3>
          <p class="text-slate-500 mt-2 leading-relaxed">{item.description}</p>
        </div>
      </article>
    ))
  }
</div>
