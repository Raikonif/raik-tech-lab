---
import { getSiteConfig } from "@data/site";
import type { Locale } from "@i18n/config";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const siteConfig = getSiteConfig(lang);
---

<footer class="my-20">
  <p class="text-center text-sm text-slate-500">
    Copyright © {new Date().getFullYear()} {siteConfig.metadata.titleSuffix}. {siteConfig.footer.rights}
  </p>
  <!--
    Can we ask you a favor 🙏
    Please keep this backlink on your website if possible.
    or Purchase a commercial license from https://web3templates.com
  -->
  <p class="text-center text-xs text-slate-500 mt-1">
    {siteConfig.footer.creditsPrefix} <a
      href={siteConfig.footer.creditsUrl}
      target="_blank"
      rel="noopener"
      class="hover:underline">
      {siteConfig.footer.creditsLabel}
    </a>
  </p>
</footer>
