---
import Container from "@components/container.astro";
import Dropdown from "./dropdown.astro";
import { getNavigationItems } from "@data/navigation";
import { getSiteConfig } from "@data/site";
import { withLocalePath } from "@i18n/config";
import type { Locale } from "@i18n/config";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

interface Props {
  lang?: Locale;
}

const { lang = "es" } = Astro.props;
const siteConfig = getSiteConfig(lang);
const navigationItems = getNavigationItems(lang);
---

<Container>
  <header class="flex flex-col lg:flex-row justify-between items-center my-5 fixed left-0 right-0 px-6 py-2 top-0 w-full bg-slate-100/95 rounded-md z-20">
    <Astronav>
      <div class="flex w-full lg:w-auto items-center justify-between">
        <a href={withLocalePath(lang, "/")} class="text-lg"
          ><span class="font-bold text-slate-800">{siteConfig.brand.name} </span><span
            class="text-slate-500">{siteConfig.brand.suffix}</span
          >
        </a>
        <div class="block lg:hidden">
          <MenuIcon class="w-4 h-4 text-gray-800" />
        </div>
      </div>
      <MenuItems class="hidden w-full lg:w-auto mt-2 lg:flex lg:mt-0">
        <ul class="flex flex-col lg:flex-row lg:gap-3">
          {
            navigationItems.map((item, index) => (
              <>
                {item.children && (
                  <Dropdown
                    title={item.title}
                    children={item.children}
                    lastItem={index === navigationItems.length - 1}
                  />
                )}

                {!item.children && (
                  <li>
                    <a
                      href={item.path}
                      class="flex lg:px-3 py-2 items-center text-gray-600 hover:text-gray-900">
                      <span> {item.title}</span>
                      {item.badge && (
                        <span class="ml-1 px-2 py-0.5 text-[10px] animate-pulse font-semibold uppercase text-white bg-indigo-600 rounded-full">
                          Nuevo
                        </span>
                      )}
                    </a>
                  </li>
                )}
              </>
            ))
          }
        </ul>
        <div class="mt-3 lg:mt-0 lg:ml-4 flex items-center gap-2">
          <a
            href={withLocalePath("es", Astro.url.pathname.replace(/^\/(es|en)/, "") || "/")}
            class:list={[
              "px-2.5 py-1 rounded text-xs border soft-transition",
              lang === "es"
                ? "bg-slate-900 text-white border-slate-900"
                : "bg-white text-slate-600 border-slate-200 hover:border-slate-400",
            ]}>ES</a>
          <a
            href={withLocalePath("en", Astro.url.pathname.replace(/^\/(es|en)/, "") || "/")}
            class:list={[
              "px-2.5 py-1 rounded text-xs border soft-transition",
              lang === "en"
                ? "bg-slate-900 text-white border-slate-900"
                : "bg-white text-slate-600 border-slate-200 hover:border-slate-400",
            ]}>EN</a>
        </div>
        <!-- <div class="lg:hidden flex items-center mt-3 gap-4">
          <Link href="#" style="muted" block size="md">Log in</Link>
          <Link href="#" size="md" block>Sign up</Link>
        </div> -->
      </MenuItems>
    </Astronav>
    <!-- <div>
      <div class="hidden lg:flex items-center gap-4">
        <a href="#">Log in</a>
        <Link href="#" size="md">Sign up</Link>
      </div>
    </div> -->
  </header>
</Container>
